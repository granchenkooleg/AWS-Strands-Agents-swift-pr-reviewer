# Provider selection: "anthropic" for local dev, "bedrock" for AWS demo
STRANDS_PROVIDER=anthropic

# Anthropic provider (local dev path)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_ID=claude-sonnet-4-5-20250929

# Bedrock provider (AWS demo path — requires sandbox credentials)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=          # uncomment for temporary STS credentials
# AWS_PROFILE=default          # alternative to access keys
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# OpenTelemetry → CloudWatch (only needed for the Bedrock demo screenshots)
# Point at a local ADOT collector running on localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=swift-pr-reviewer

# Bypass community-tool consent prompts in non-interactive runs (eval, CI)
BYPASS_TOOL_CONSENT=false
